# Toast Menus API credentials for the live /api/menu endpoint.
# Copy to .env for LOCAL testing (.env is gitignored), and set the same keys in
# the Vercel dashboard: Project -> Settings -> Environment Variables.
# NEVER commit real values.

# Toast API hostname. Production for a live restaurant:
TOAST_API_HOST=https://ws-api.toasttab.com
# Sandbox alternative: https://ws-sandbox-api.toasttab.com

# Issued by Toast support / the Toast developer portal for your integration:
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=

# Your restaurant's GUID / externalId (sent as the Toast-Restaurant-External-ID header):
TOAST_RESTAURANT_GUID=

# --- Ordering (POST /api/order, pay-at-pickup) ---
# Takeout dining option GUID for this restaurant (required to place orders):
TOAST_DINING_OPTION_GUID=
# Revenue center GUID (optional; some Toast configs require it):
TOAST_REVENUE_CENTER_GUID=

# --- Clerk authentication ---
# From Clerk Dashboard -> API Keys.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional override: Clerk frontend API host from the JavaScript quick-copy
# snippet, for example: your-app.clerk.accounts.dev
CLERK_FRONTEND_API_URL=

# Optional hardening: comma-separated allowed origins for Clerk token verification.
# Example: http://localhost:4173,https://www.illynationalharbor.com
CLERK_AUTHORIZED_PARTIES=

# Optional: comma-separated admin allowlist. The super admin email
# oliyad@thelivingstonefoundation.com is always promoted server-side.
ADMIN_EMAILS=
